# Required: Encryption key for API key storage (AES-256-GCM)
AI_CHAT_ENCRYPTION_KEY=your-random-encryption-key-here

# Optional: Server port (default: 3001)
# PORT=3001

# Optional: SQLite database path (default: data.db in project root)
# AI_CHAT_CHAT_DB_PATH=/path/to/data.db

# Optional: QWeather (weather agent)
# QWEATHER_PROJECT_ID=your-project-id
# QWEATHER_KEY_ID=your-key-id
# QWEATHER_PRIVATE_KEY=your-ed25519-private-key-pem
