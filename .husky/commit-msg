COMMIT_MSG="$1"
HEADER=$(head -1 "$COMMIT_MSG")

# Skip merge commits
if echo "$HEADER" | grep -qE '^Merge '; then
  exit 0
fi

# Validate Conventional Commits format
if ! echo "$HEADER" | grep -qE '^(feat|fix|refactor|perf|style|test|docs|chore|ci)(\([a-z0-9._/-]+\))?: .+$'; then
  echo ""
  echo "  ✗ Invalid commit message format"
  echo ""
  echo "  Expected: <type>(<scope>): <description>"
  echo ""
  echo "  Types: feat | fix | refactor | perf | style | test | docs | chore | ci"
  echo ""
  echo "  Examples:"
  echo "    feat(ui): add theme switcher"
  echo "    fix(sse): handle empty buffer on stream end"
  echo "    refactor: extract endpoint service"
  echo "    chore: bump express to 4.21"
  echo ""
  exit 1
fi

# Check description length (≤ 72 chars)
LEN=$(echo "$HEADER" | wc -c | tr -d ' ')
if [ "$LEN" -gt 73 ]; then
  echo ""
  echo "  ✗ Commit title exceeds 72 characters ($((LEN - 1)))"
  echo ""
  exit 1
fi

exit 0
