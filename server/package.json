{
  "name": "mint-server",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "cli": "tsx cli/index.ts",
    "cli:serve": "tsx cli/index.ts serve",
    "start": "node --dns-result-order=ipv4first dist/index.js",
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' tsx watch index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "bin": {
    "mint": "./dist/cli/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-everything": "^2026.1.26",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.1.0",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jose": "^6.2.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/uuid": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^1.6.1"
  }
}
